# Database Configuration
POSTGRES_DB=retention_brain
POSTGRES_USER=rb_admin
POSTGRES_PASSWORD=your_secure_password_here

# Backend Configuration
JWT_SECRET=your_jwt_secret_here
DATABASE_URL=postgresql://rb_admin:your_secure_password_here@postgres:5432/retention_brain
REDIS_URL=redis://redis:6379/0
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Force SQLite for local testing without Docker
# DATABASE_URL=sqlite:///./retention_brain.db

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
# For production, set to your domain or public IP
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
